# Local development env for VITAL_Services running standalone (not via root compose).
# Copy to `.env` and adjust to your local Postgres / RabbitMQ / Auth setup.
#
# When running through the root BGH workspace compose, this file is NOT used —
# the root `.env.vital_services` (templated from `.env.vital_services.example` at
# the workspace root) takes precedence and uses Docker hostnames instead of localhost.

PORT=8009
NODE_ENV=development

# Trust model (must match BGH_API_GATEWAY when integrating)
GATEWAY_SECRET=BGH_LOCAL_GATEWAY_SECRET_2026
INTERNAL_API_KEY=BGH_LOCAL_INTERNAL_API_KEY_2026
INTERNAL_SERVICE_NAME=vital-services
# Set to false to bypass X-Gateway-Secret enforcement during local-only testing.
GATEWAY_TRUST_ENABLED=true

# JWT verification (must match UHSE_AUTH issuance)
JWT_SECRET=BGH_LOCAL_JWT_SECRET_2026_CHANGE_ME
JWT_ALGORITHM=HS256

# Direct calls back to UHSE_AUTH /internal/* (control plane, NOT via Gateway)
AUTH_INTERNAL_BASE_URL=http://localhost:8000
AUTH_SYSTEM_SLUG=vital
AUTH_SYSTEM_CLIENT_ID=bgh_vital_client
AUTH_SYSTEM_CLIENT_SECRET=CHANGE-ME-vital-secret-min-16-chars
AUTH_INTERNAL_SERVICE_KEY=BGH_LOCAL_VITAL_TO_AUTH_KEY_2026

# Postgres (local instance)
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=vital_services_db
DATABASE_URL=postgresql://postgres:password@localhost:5435/vital_services_db

# Audit / RabbitMQ (matches BGH_AUDIT_LOGS exchange)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
AUDIT_EXCHANGE=audit.events
AUDIT_TIMEZONE=Asia/Manila

# Observability (optional locally)
LOKI_ENDPOINT=http://localhost:3100/loki/api/v1/push
PROMETHEUS_ENDPOINT=http://localhost:9090/api/v1/write
